                const sel = document.getElementById('alumno-docente-sel');
                if(sel) {
                    const docentes = db.usuarios.filter(u => u.rol === 'docente');
                    sel.innerHTML = '<option value="">-- Selecciona docente --</option>';
                    docentes.forEach(d => {
                        const ctmp = d.colegiatura ? ' (CTMP: '+ctmpLimpio(d.colegiatura)+')' : '';
                        sel.innerHTML += `<option value="${d.usuario}">${d.nombre_completo}${ctmp}</option>`;
                    });
