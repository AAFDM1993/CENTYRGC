    // Función para formatear fechas (tanto nuevas como antiguas)
    function formatearFecha(fechaStr) {
        // Si ya está en formato DD/MM/YYYY HH:MM AM/PM, retornar tal cual
        if (fechaStr && fechaStr.includes('/') && (fechaStr.includes('AM') || fechaStr.includes('PM'))) {
            return fechaStr;
        }
        
        // Si es formato ISO (2026-02-17T00:16:33.000Z), convertir
        try {
            const fecha = new Date(fechaStr);
            
            const dia = String(fecha.getDate()).padStart(2, '0');
            const mes = String(fecha.getMonth() + 1).padStart(2, '0');
            const anio = String(fecha.getFullYear()).slice(-2); // Solo 2 dígitos
            
            let horas = fecha.getHours();
            const minutos = String(fecha.getMinutes()).padStart(2, '0');
            const ampm = horas >= 12 ? 'PM' : 'AM';
            horas = horas % 12;
            horas = horas ? horas : 12;
            const horasStr = String(horas).padStart(2, '0');
            
            return `${dia}/${mes}/${anio} ${horasStr}:${minutos} ${ampm}`;
        } catch (e) {
            return fechaStr; // Si falla, retornar original
        }
    }

