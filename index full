                ? (data.notas.reduce((s,n)=>s+parseFloat(n.calificacion||0),0)/data.notas.length).toFixed(1)
                : null;
            const col = !prom ? '#888' : prom <= 10 ? '#E53935' : prom <= 13 ? '#F59E0B' : prom <= 16 ? '#2ECC71' : '#0288D1';

